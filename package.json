{
  "name": "cross-platform-calculator",
  "version": "1.0.0",
  "description": "跨平台科学计算器 - 支持HarmonyOS、Web、平板",
  "main": "index.js",
  "scripts": {
    "build:harmony": "hvigorw assembleHap --mode module -p product=default",
    "build:web": "hvigorw assembleWeb --mode module -p product=web",
    "build:all": "npm run build:harmony && npm run build:web",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.ets",
    "lint:fix": "eslint . --ext .ts,.ets --fix"
  },
  "keywords": [
    "calculator",
    "cross-platform",
    "arkui-x",
    "harmonyos",
    "web"
  ],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.50.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
